# ==========================================
# RollingGo Hotel CLI 环境变量配置参考
# ==========================================

# 1. MCP 业务接口基础地址
# 默认值: https://travelportal-api-staging.aigohotel.com/api/mcp
# MCP_BASE_URL=https://mcp.rollinggo.cn/mcp

# 2. OAuth 中转服务器地址 (您的自建服务器)
# 默认值: https://rollinggo.store
# OAUTH_SERVER_URL=https://rollinggo.store

# 3. Dida/MCP OAuth 授权页面地址
# 默认值: https://mcp.rollinggo.cn/oauth2/authorize
# OAUTH_AUTHORIZE_URL=https://mcp.rollinggo.cn/oauth2/authorize

# 4. OAuth Client ID
# 默认值: rollinggo-skill
# CLIENT_ID=rollinggo-skill
